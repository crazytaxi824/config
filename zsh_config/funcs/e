# vim: ft=zsh

# 使用方法: `e file` 检查 file 是否存在

# 使用数组存储不存在的 file
local -a notexistfiles=()

local arg
for arg in "$@"; do
	# -e 同时检查文件和目录
	if [[ ! -e "$arg" ]]; then
		notexistfiles+=("$arg")
	fi
done

# 检查数组长度
if (( ${#notexistfiles} > 0 )); then
	# 使用 (j:, :) 拼接数组，显示更美观
	print -P "%F{red}error:%f no such file or directory: %F{yellow}${(j:, :)notexistfiles}%f"
	return 2
fi

# 执行
# 注意：这里必须给 "$@" 加引号，否则文件名里的空格会把命令切碎
$EDITOR "$@"



