# vim: ft=gitconfig

# delta diff tool
# https://dandavison.github.io/delta/configuration.html
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = diff3

[diff]
	colorMoved = default

[delta]
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
	line-numbers = true  # Display line numbers.
	### delta --no-gitconfig BUG: https://github.com/dandavison/delta/issues/1271
	# side-by-side = true  # Display diffs in side-by-side.
	max-line-length = 512  # chars 超过该值会被丢弃. 防止超长 js line 导致程序崩溃.
	
	### The width of underline/overline decorations.
	### variable: to the end of the text only
	### -2: screen_size - 2
	### omit: full terminal width
	# width = variable

	### colors -------------------------------------------------------------------------------------
	### `$ delta --list-syntax-themes`
	### none: 表示不使用 syntax highlight.
	syntax-theme = none

	### filename decoration color and overline
	file-decoration-style = blue ol  # blue
	### filename color
	file-style = blue  # blue

	### syntax 表示 text fg 使用 syntax-theme highlight.
	### 如果 syntax-theme 设置为 none, 则会使用 white/normal 作为 fg 颜色.
	minus-style = 242 "#300000"
	minus-emph-style = 243 "#803030"
	line-numbers-minus-style = red
	plus-style = green
	plus-emph-style = 233 green
	line-numbers-plus-style = green

	### commit hash 颜色, 继承 gitconfig [color diff] commit 设置
	# commit-decoration-style = yellow ol  # yellow
	# commit-style = yellow  # yellow



